# Copy to .env for local use with docker-compose.prod.yml, or paste these as
# environment variables in the Coolify resource configuration.

# --- Images ---
# GitHub org/user that owns the GHCR packages (lowercase), e.g. donilite
GHCR_OWNER=
# Image tag to deploy: "latest" or a specific commit sha pushed by CI
IMAGE_TAG=latest

# --- Postgres ---
POSTGRES_DB=calendary
POSTGRES_USER=calendary
POSTGRES_PASSWORD=

# --- Backend / mail ---
CALENDARY_MAIL_FROM=
CALENDARY_MAIL_REPLY_TO=
CALENDARY_PUBLIC_BASE_URL=https://your-domain.example
SPRING_MAIL_HOST=
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=

# --- Backend / Backblaze B2 storage (optional) ---
CALENDARY_B2_ENABLED=false
CALENDARY_B2_KEY_ID=
CALENDARY_B2_APPLICATION_KEY=
CALENDARY_B2_BUCKET_ID=
CALENDARY_B2_BUCKET_NAME=
CALENDARY_B2_DOWNLOAD_TTL_SECONDS=900

# --- Backend / Google Calendar conferencing (optional) ---
CALENDARY_GOOGLE_CALENDAR_ENABLED=false
CALENDARY_GOOGLE_CALENDAR_ID=
CALENDARY_GOOGLE_SERVICE_ACCOUNT_EMAIL=
CALENDARY_GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# --- Frontend (build-time only, NOT read by the running container) ---
# These are baked into the static bundle by Vite at image build time.
# Set them as repository Variables in GitHub (Settings > Secrets and
# variables > Actions > Variables), not here: VITE_CALENDARY_PUBLIC_SLUG,
# VITE_CALENDARY_WORKSPACE_ID. Changing them requires re-running CI to
# rebuild the frontend image, not just redeploying.
